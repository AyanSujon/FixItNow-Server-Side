model Payment {
  id                String   @id @default(uuid())

  bookingId         String   @unique
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  customerId        String
  customer          User     @relation("CustomerPayments", fields: [customerId], references: [id])

  amount            Float

  method            PaymentMethod
  provider          PaymentProvider

  status            PaymentStatus @default(PENDING)
stripeCustomerId String? 
  transactionId     String?  @unique
  paymentIntentId   String?  @unique // Stripe PaymentIntent ID
  sessionId         String?  @unique // Stripe Checkout Session ID

  currency          CurrencyType   @default(USD)

  paidAt            DateTime?

  failureReason     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([customerId])
  @@index([bookingId])
  @@index([status])
}